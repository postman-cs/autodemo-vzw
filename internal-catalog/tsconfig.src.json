{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["@cloudflare/vitest-pool-workers/types"],
    "paths": {
      "node:fs/promises": ["./src/types/node-fs-promises"],
      "node:path": ["./src/types/node-path"],
      "@vzw/types": ["../packages/types/src"]
    }
  },
  "include": ["src/**/*", "worker-configuration.d.ts", ".github/actions/_lib/**/*"],
  "exclude": ["node_modules", "dist"]
}
