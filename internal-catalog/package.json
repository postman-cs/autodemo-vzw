{
  "name": "vzw-internal-catalog",
  "version": "1.0.0",
  "description": "Verizon internal service deployment portal for the partner demo",
  "main": "src/index.ts",
  "scripts": {
    "postinstall": "bash scripts/install-hooks.sh >/dev/null 2>&1 || true",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:worker": "wrangler dev --config wrangler.toml",
    "extract:spec-descriptions": "node scripts/extract-spec-descriptions.mjs",
    "prebuild": "node scripts/extract-spec-descriptions.mjs",
    "build": "vite build --config frontend/vite.config.ts",
    "pretest": "pkill -9 workerd 2>/dev/null || true",
    "test": "node scripts/run-tests.mjs",
    "check:204-no-body": "node scripts/check-no-content-204.mjs",
    "test:regression": "npm run check:204-no-body && vitest run tests/config.test.ts tests/provision-workflow.test.ts tests/provision.test.ts tests/resource-inventory.test.ts tests/dependency-planner.test.ts tests/provision-graph.test.ts",
    "test:regression:full": "npm run check:204-no-body && vitest run tests/config.test.ts tests/provision-workflow.test.ts tests/provision.test.ts tests/resource-inventory.test.ts tests/teardown.test.ts tests/dependency-planner.test.ts tests/provision-graph.test.ts",
    "deploy": "npm run build && wrangler deploy --config wrangler.toml",
    "backfill:postman-spec-uids": "node scripts/backfill-postman-spec-uids.mjs",
    "backfill:finalize-runner": "node scripts/backfill-finalize-runner.mjs",
    "backfill:urls": "npx tsx scripts/backfill-urls.ts",
    "validate:graph": "node scripts/validate-dependencies.mjs",
    "test:fern-harness": "node scripts/run-fern-regression-harness.mjs",
    "validate:specs": "vitest run --config vitest.node.config.ts",
    "validate:design-system": "node scripts/validate-design-system.mjs --scope changed",
    "validate:design-system:all": "node scripts/validate-design-system.mjs --scope all",
    "check:bun-lock": "node scripts/check-bun-lock.mjs",
    "test:precommit": "vitest run --config vitest.precommit.config.ts",
    "test:design-system": "vitest run tests/precommit/design-system-validator.test.ts --config vitest.precommit.config.ts",
    "test:actions": "vitest run --config vitest.actions.config.ts",
    "build:actions": "./scripts/build-actions.sh",
    "typecheck": "tsc --noEmit --project tsconfig.src.json && tsc --noEmit --project tsconfig.test.json",
    "dev": "LOCAL_DEV_AUTH_MODE=bypass vite dev --config frontend/vite.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postman-cs/vzw-partner-demo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/postman-cs/vzw-partner-demo/issues"
  },
  "homepage": "https://github.com/postman-cs/vzw-partner-demo#readme",
  "devDependencies": {
    "@cloudflare/containers": "^0.1.1",
    "@cloudflare/vite-plugin": "^1.28.0",
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/ncc": "^0.38.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "undici": "^7.24.2"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/io": "^3.0.2",
    "@floating-ui/react-dom": "^2.1.8",
    "@xyflow/react": "^12.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-sealedbox-js": "^1.2.0",
    "tweetnacl-util": "^0.15.1",
    "yaml": "^2.8.2"
  }
}
